{
  "editor.formatOnSave": true,
  "editor.wordWrap": "off",
  "json.schemas": [
    {
      "fileMatch": [
        "/.markdownlint.json"
      ],
      "url": "https://raw.githubusercontent.com/DavidAnson/markdownlint/v0.41.1/schema/markdownlint-config-schema.json"
    }
  ],
  "search.exclude": {
    "**/target/": true,
    "**/Cargo.lock": true,
    ".git/": true
  },
  "rust-analyzer.rustfmt.extraArgs": [
    "+nightly"
  ],
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.wordWrap": "on"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.tabSize": 4
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.tabSize": 2
  },
}
